{
  "name": "claude-agent-monitor",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Fully local, live dashboard for watching Claude Code (and other) agent sessions and their subagents. React + TypeScript + Redux Toolkit + Tailwind, served by a zero-external Node/Bun backend.",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c green,cyan \"bun run dev:server\" \"vite\"",
    "dev:server": "bun run --watch server/server.ts",
    "server": "bun run server/server.ts",
    "typecheck": "tsc -b --noEmit",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.7",
    "framer-motion": "^11.3.0",
    "goey-toast": "^0.5.0",
    "react": "^19",
    "react-dom": "^19",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^7"
  }
}
